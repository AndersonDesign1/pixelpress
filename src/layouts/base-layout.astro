---
import "@/styles/global.css";
import {
  SITE_ISSUES_URL,
  SITE_LICENSE_URL,
  SITE_REPO_URL,
} from "@/lib/utils/site";

interface Props {
  description: string;
  title: string;
}

const { title, description } = Astro.props;
const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url
).toString();
const currentPath =
  Astro.url.pathname !== "/" && Astro.url.pathname.endsWith("/")
    ? Astro.url.pathname.slice(0, -1)
    : Astro.url.pathname;
const nav = [
  { href: "/about", label: "About" },
  { href: "/changelog", label: "Changelog" },
];

const navLinkClass =
  "inline-flex items-center rounded-full px-2.5 py-1.5 text-[0.82rem] font-medium text-white/52 transition hover:text-text";
const footerLinkClass =
  "inline-flex items-center text-[0.82rem] font-medium text-white/52 transition hover:text-text";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={canonical}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    >
  </head>
  <body class="min-h-screen overflow-x-clip bg-bg-deep text-text">
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(ellipse_80%_50%_at_50%_-12%,rgba(255,255,255,0.06),transparent),linear-gradient(rgba(255,255,255,0.014)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.014)_1px,transparent_1px),linear-gradient(#050505,#050505)] [background-position:0_0,0_0,0_0,0_0] [background-size:auto,80px_80px,80px_80px,auto]"
      style="mask-image: linear-gradient(180deg, rgb(0 0 0 / 0.6), transparent 60%);"
    ></div>

    <header
      data-site-header
      class="sticky top-0 z-20 border-b border-white/5 bg-black/72 backdrop-blur-xl transition-[background-color,border-color,box-shadow] duration-300 ease-out"
    >
      <div class="mx-auto flex w-[min(1140px,calc(100%-2rem))] flex-wrap items-center justify-between gap-5 px-0 py-4 md:gap-4">
        <a class="inline-flex items-center gap-4 no-underline" href="/">
          <span
            aria-hidden="true"
            class="inline-flex size-10 items-center justify-center rounded-[0.85rem] border border-white/9 bg-[linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.02)),linear-gradient(rgba(10,10,10,0.9),rgba(10,10,10,0.9))] text-text shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_14px_24px_rgba(0,0,0,0.2)]"
          >
            <svg
              aria-hidden="true"
              focusable="false"
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              stroke="currentColor"
              stroke-width="1.2"
              stroke-linejoin="round"
            >
              <path d="M9 2L16 6V12L9 16L2 12V6L9 2Z" />
            </svg>
          </span>
          <span class="inline-flex flex-col gap-[0.18rem]">
            <span class="font-display text-base font-bold tracking-[-0.05em] text-text">
              PixelPress
            </span>
            <span class="max-w-[24rem] text-[0.72rem] tracking-[0.015em] text-white/54">
              Local-first batch compression for design-heavy work
            </span>
          </span>
        </a>

        <nav class="flex flex-wrap justify-start gap-1 sm:justify-end" aria-label="Primary">
          {nav.map((item) => (
            <a
              aria-current={currentPath === item.href ? "page" : undefined}
              class:list={[
                navLinkClass,
                currentPath === item.href && "text-text",
              ]}
              href={item.href}
              key={item.href}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="py-0">
      <div class="mx-auto grid w-[min(1140px,calc(100%-2rem))] gap-[clamp(4rem,8vw,8rem)] px-0 py-0">
        <slot />
      </div>
    </main>

    <footer class="border-t border-white/5 bg-[rgba(7,7,7,0.94)]">
      <div class="mx-auto flex w-[min(1140px,calc(100%-2rem))] flex-col items-start justify-between gap-6 px-0 py-[1.8rem] pb-[2.6rem] md:flex-row">
        <div class="max-w-[36rem]">
          <p class="mb-[0.65rem] inline-flex items-center gap-[0.45rem] text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-white/72 before:h-px before:w-[1.8rem] before:bg-white/28 before:content-['']">
            PixelPress
          </p>
          <p class="font-display text-[1.08rem] tracking-[-0.03em] text-text">
            Built because batch image work got old.
          </p>
          <p class="mt-[0.35rem] max-w-[34rem] text-[0.95rem] leading-[1.6] text-white/52">
            PixelPress exists because I wanted one local-first tool for the
            image work that keeps showing up in real projects: exports, handoff
            assets, screenshots, conversions, and batch cleanup.
          </p>
        </div>

        <div class="grid gap-2 md:justify-items-end">
          <a
            class={footerLinkClass}
            href={SITE_REPO_URL}
            target="_blank"
            rel="noreferrer"
          >
            View source
          </a>
          <a
            class={footerLinkClass}
            href={SITE_ISSUES_URL}
            target="_blank"
            rel="noreferrer"
          >
            Raise an issue
          </a>
          <a
            class={footerLinkClass}
            href={SITE_LICENSE_URL}
            target="_blank"
            rel="noreferrer"
          >
            MIT license
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      const root = document.documentElement;
      const header = document.querySelector("[data-site-header]");

      const syncScrollState = () => {
        const isScrolled = window.scrollY > 12;

        if (!header) {
          return;
        }

        header.classList.toggle("bg-black/90", isScrolled);
        header.classList.toggle("border-white/10", isScrolled);
        header.classList.toggle(
          "shadow-[0_26px_60px_rgba(0,0,0,0.34)]",
          isScrolled
        );
      };

      syncScrollState();
      window.addEventListener("scroll", syncScrollState, { passive: true });

      if (!reducedMotion) {
        root.dataset.motion = "enabled";

        const heroItems = Array.from(
          document.querySelectorAll('[data-reveal-group="hero"] [data-reveal]')
        );

        for (const [index, item] of heroItems.entries()) {
          item.style.setProperty("--reveal-delay", `${index * 95}ms`);
        }

        requestAnimationFrame(() => {
          for (const item of heroItems) {
            item.dataset.visible = "true";
          }
        });

        const scrollItems = Array.from(
          document.querySelectorAll(
            '[data-reveal-group="scroll"] [data-reveal]'
          )
        );

        for (const [index, item] of scrollItems.entries()) {
          item.style.setProperty("--reveal-delay", `${(index % 3) * 80}ms`);
        }

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) {
                continue;
              }

              entry.target.dataset.visible = "true";
              observer.unobserve(entry.target);
            }
          },
          {
            threshold: 0.16,
            rootMargin: "0px 0px -10% 0px",
          }
        );

        for (const item of scrollItems) {
          observer.observe(item);
        }
      }
    </script>
  </body>
</html>
