---
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const currentPath = Astro.url.pathname !== '/' && Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname.slice(0, -1)
  : Astro.url.pathname;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/features', label: 'Features' },
  { href: '/about', label: 'About' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/docs', label: 'Docs' },
  { href: '/app', label: 'Open App' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="site-body">
    <header class="site-header">
      <div class="container-shell site-header-inner">
        <a class="site-brand" href="/">
          <span class="site-brand-mark">PixelPress</span>
          <span class="site-brand-note">Local-first image compression</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {nav.map((item) => (
            <a
              class="site-link"
              href={item.href}
              aria-current={(item.href === '/'
                ? currentPath === '/'
                : currentPath === item.href)
                ? 'page'
                : undefined}
              data-active={item.href === '/'
                ? currentPath === '/'
                : currentPath === item.href}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="site-main">
      <div class="container-shell">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container-shell site-footer-inner">
        <div>
          <p class="site-footer-title">PixelPress</p>
          <p class="site-footer-copy">Compression stays on-device, exports stay quick, and the workflow stays quiet.</p>
        </div>
        <p class="site-footer-meta">Built with Astro and React for creators who need privacy, speed, and batch-ready output.</p>
      </div>
    </footer>
  </body>
</html>
