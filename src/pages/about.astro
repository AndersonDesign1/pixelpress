---
import BaseLayout from "@/layouts/base-layout.astro";
import { SITE_PERSONAL_URL, SITE_REPO_URL } from "@/lib/utils/site";
---

<BaseLayout
  title="About — PixelPress"
  description="Why PixelPress exists and what it tries to do."
>
  <section class="grid gap-8">
    <div class="max-w-[42rem] space-y-4">
      <p class="text-[0.72rem] uppercase tracking-[0.18em] text-white/40">
        Why I built this
      </p>
      <h1
        class="max-w-[15ch] font-display text-[clamp(2rem,4vw,3.2rem)] leading-[1.02] tracking-[-0.05em] text-text"
      >
        I wanted a calmer way to do this.
      </h1>
      <p class="text-[1rem] leading-7 text-white/58">
        TinyPNG is handy until you hit the free limit. Squash was great for a
        while, but it is no longer maintained. I wanted one local tool that
        could handle bigger batches without making me think about limits first.
      </p>
      <p class="text-[1rem] leading-7 text-white/58">
        PixelPress runs in the browser, keeps the work on your machine, and now
        lets you compare versions instead of guessing which one to keep.
      </p>
      <div class="flex flex-wrap gap-4 text-sm text-white/68">
        <a
          class="underline decoration-white/15 underline-offset-4 hover:decoration-white/55 hover:text-text"
          href={SITE_REPO_URL}
          target="_blank"
          rel="noreferrer"
        >
          GitHub
        </a>
        <a
          class="underline decoration-white/15 underline-offset-4 hover:decoration-white/55 hover:text-text"
          href={SITE_PERSONAL_URL}
          target="_blank"
          rel="noreferrer"
        >
          andersonjoseph.com
        </a>
      </div>
    </div>
  </section>

  <section class="grid gap-4 border-t border-border pt-5">
    <p class="text-[0.72rem] uppercase tracking-[0.18em] text-white/40">
      What matters
    </p>
    <div
      class="grid gap-3 text-[0.98rem] leading-7 text-white/58 sm:grid-cols-2"
    >
      <p>
        Local-first. Batch compression. Version comparison. Format conversion.
      </p>
      <p>Built with jSquash, web workers, Astro, and a small React app.</p>
    </div>
  </section>
</BaseLayout>
