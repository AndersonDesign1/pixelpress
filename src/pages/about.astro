---
import BaseLayout from "@/layouts/base-layout.astro";
import { SITE_ISSUES_URL, SITE_REPO_URL } from "@/lib/utils/site";

const features = [
  {
    title: "Drop a full batch",
    description:
      "Throw a pile of screenshots or exported assets at it instead of feeding files one by one.",
  },
  {
    title: "Convert formats in the same flow",
    description:
      "Switch between JPEG, PNG, WebP, and AVIF inside the same workspace.",
  },
  {
    title: "Preview before exporting",
    description:
      "Side-by-side preview to catch bad output quickly instead of trusting blind compression.",
  },
  {
    title: "Presets for speed",
    description:
      "Reach for familiar defaults when you just want a decent result and need to keep moving.",
  },
  {
    title: "Zip the whole run",
    description:
      "Download a single image or the full output set once the batch is done.",
  },
  {
    title: "Remembers your setup",
    description:
      "The app keeps your recent settings locally so repeated image work takes fewer clicks.",
  },
];
---

<BaseLayout
  title="About — PixelPress"
  description="Why PixelPress exists and what it does."
>
  <section class="grid gap-8">
    <div class="grid max-w-[38rem] gap-8" data-reveal-group="hero">
      <div>
        <p
          class="inline-flex items-center gap-2 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-white/72 before:h-px before:w-7 before:bg-white/30 before:content-['']"
          data-reveal
        >
          About
        </p>
        <h1
          class="mt-4 max-w-[13ch] font-display text-[clamp(2.8rem,6vw,4.9rem)] leading-[0.96] tracking-[-0.06em] text-text"
          data-reveal
        >
          I got tired of image tools that break on real batches.
        </h1>
        <p
          class="mt-4 text-[clamp(0.95rem,1.3vw,1.05rem)] leading-[1.85] text-white/52"
          data-reveal
        >
          I work with screenshots, Figma exports, designer handoff assets, and
          product images constantly. Most web compressors either cap uploads,
          gate conversion behind a paywall, or send everything through a hosted
          service. PixelPress runs entirely in your browser using jSquash codecs
          and web workers&mdash;nothing leaves your machine.
        </p>
      </div>
      <div class="flex flex-wrap gap-2" data-reveal>
        <a
          class="inline-flex min-h-10 items-center rounded-2xl border border-white/8 bg-white/3 px-4 text-sm font-medium text-white/72 transition-colors duration-200 hover:border-border-strong hover:bg-white/7 hover:text-text"
          href={SITE_REPO_URL}
          target="_blank"
          rel="noreferrer"
        >
          Source
        </a>
        <a
          class="inline-flex min-h-10 items-center rounded-2xl border border-white/8 bg-white/3 px-4 text-sm font-medium text-white/72 transition-colors duration-200 hover:border-border-strong hover:bg-white/7 hover:text-text"
          href={SITE_ISSUES_URL}
          target="_blank"
          rel="noreferrer"
        >
          Issues
        </a>
      </div>
    </div>
  </section>

  <section class="grid gap-8">
    <div class="max-w-[44rem]" data-reveal-group="scroll">
      <p
        class="inline-flex items-center gap-2 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-white/72 before:h-px before:w-7 before:bg-white/30 before:content-['']"
        data-reveal
      >
        Capabilities
      </p>
      <h2
        class="mt-4 max-w-[13ch] font-display text-[clamp(2.8rem,6vw,4.9rem)] leading-[0.96] tracking-[-0.06em] text-text"
        data-reveal
      >
        What it does.
      </h2>
    </div>
    <div class="grid border-t border-white/8" data-reveal-group="scroll">
      {features.map((feature, index) => (
        /* biome-ignore lint/correctness/useJsxKeyInIterable: Astro iterables do not use React keys. */
        <article
          class="grid gap-3 border-white/8 border-t py-5 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] md:gap-12 md:py-7"
          data-reveal
        >
          <div class="flex gap-4 md:gap-8">
            <span class="shrink-0 font-bold text-[0.72rem] text-white/30 tracking-[0.16em]">
              {String(index + 1).padStart(2, "0")}
            </span>
            <h3 class="font-display text-[clamp(1.1rem,1.8vw,1.4rem)] text-text leading-[1.12] tracking-[-0.04em]">
              {feature.title}
            </h3>
          </div>
          <p class="m-0 text-[0.92rem] text-white/44 leading-[1.65]">
            {feature.description}
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
