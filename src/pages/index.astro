---
import "@/styles/global.css";
import CompressorApp from "@/components/app/compressor-app";

const headerLinkClass =
  "inline-flex min-h-8 items-center rounded-md px-2.5 text-sm font-medium text-muted transition-colors duration-200 hover:bg-white/5 hover:text-text";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PixelPress — Local-first batch image compression</title>
    <meta
      name="description"
      content="Compress images in-browser with format selection, quality control, and zip export. Nothing leaves your machine."
    >
    <link
      rel="canonical"
      href={new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString()}
    >
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    >
  </head>
  <body class="min-h-screen bg-bg-deep font-body text-text">
    <header
      class="border-b border-border bg-[rgb(8_8_8_/_0.9)] backdrop-blur-sm"
    >
      <div class="flex items-center justify-between gap-4 px-4 py-2.5">
        <a
          class="inline-flex items-center gap-2 font-display text-[0.95rem] font-bold tracking-[-0.03em] text-text no-underline"
          href="/"
        >
          <svg
            aria-hidden="true"
            focusable="false"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linejoin="round"
          >
            <path d="M9 2L16 6V12L9 16L2 12V6L9 2Z" />
          </svg>
          PixelPress
        </a>
        <nav class="flex items-center gap-1">
          <a class={headerLinkClass} href="/about">About</a>
          <a class={headerLinkClass} href="/changelog">Changelog</a>
        </nav>
      </div>
    </header>
    <main class="flex min-h-[calc(100vh-3rem)] flex-col">
      <CompressorApp client:only="react" />
    </main>
  </body>
</html>
