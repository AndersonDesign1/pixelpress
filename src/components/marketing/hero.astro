---
import { SITE_ISSUES_URL, SITE_REPO_URL } from "@/lib/utils/site";

interface Props {
  subtitle: string;
  title: string;
}

const { title, subtitle } = Astro.props;
---

<section class="hero-shell" data-reveal-group="hero">
  <div class="hero-copy">
    <p class="section-label" data-reveal>
      Built for the annoying part of image work
    </p>
    <h1 class="page-title hero-title" data-reveal>{title}</h1>
    <p class="page-intro hero-intro" data-reveal>{subtitle}</p>
    <ul class="hero-inline-list" data-reveal>
      <li>No upload caps</li>
      <li>Batch conversion in one go</li>
      <li>Everything stays on your machine</li>
    </ul>
    <div class="action-row hero-actions" data-reveal>
      <a href="/" class="button-primary">Open Workspace</a>
      <a href="/about" class="button-secondary">See What It Covers</a>
      <a
        href={SITE_REPO_URL}
        class="button-tertiary"
        target="_blank"
        rel="noreferrer"
      >
        Read The Code
      </a>
    </div>
  </div>
  <aside class="hero-aside surface-panel" data-reveal>
    <p class="panel-kicker">Why it exists</p>
    <h2 class="hero-aside-title">
      Most image tools got weird the moment the batch was real.
    </h2>
    <div class="hero-stack">
      <article class="hero-stack-item">
        <span class="hero-list-label">Upload caps</span>
        <p>
          I kept running into tools that stopped being useful after a few files
          or a tiny upload limit.
        </p>
      </article>
      <article class="hero-stack-item">
        <span class="hero-list-label">Developer workflow</span>
        <p>
          I work with screenshots, assets, and exported designs constantly, so I
          wanted one quiet tool that could handle all of it.
        </p>
      </article>
      <article class="hero-stack-item">
        <span class="hero-list-label">Open by default</span>
        <p>
          It runs locally, the code is public, and if something breaks you can
          inspect it or raise an issue.
        </p>
      </article>
    </div>
    <div class="hero-link-row">
      <a href={SITE_REPO_URL} target="_blank" rel="noreferrer">Source</a>
      <a href={SITE_ISSUES_URL} target="_blank" rel="noreferrer">Issues</a>
    </div>
  </aside>
</section>
