---
interface Feature {
  title: string;
  description: string;
}
interface Props {
  features: Feature[];
}
const { features } = Astro.props;
---
<section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {features.map((feature) => (
    <article class="rounded-xl border border-white/10 bg-white/5 p-5">
      <h3 class="text-lg font-semibold text-white">{feature.title}</h3>
      <p class="mt-2 text-sm text-slate-300">{feature.description}</p>
    </article>
  ))}
</section>
