---
interface Feature {
  title: string;
  description: string;
}
interface Props {
  features: Feature[];
}
const { features } = Astro.props;
---
<section class="feature-grid">
  {features.map((feature, index) => (
    <article class:list={['feature-card surface-panel', (index === 0 || index === 4) && 'feature-card-wide']}>
      <p class="feature-index">{String(index + 1).padStart(2, '0')}</p>
      <h3 class="feature-title">{feature.title}</h3>
      <p class="feature-description">{feature.description}</p>
    </article>
  ))}
</section>
